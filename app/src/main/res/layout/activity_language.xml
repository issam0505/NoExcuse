<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:background="#0D0D0D"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardLanguage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="25dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="30dp"
                android:text="Choisir votre langue"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFr"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#262626"
                android:text="Français"
                android:textAllCaps="false"
                android:textColor="#BFBFBF"
                app:cornerRadius="12dp"

                app:icon="@drawable/france"
                app:iconGravity="textEnd"
                app:iconSize="28dp"
                app:iconPadding="20dp"
                android:paddingEnd="40dp"  app:iconTint="@null"
                app:strokeColor="#3D3D3D"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#262626"
                android:text="English"
                android:textAllCaps="false"
                android:textColor="#BFBFBF"
                app:cornerRadius="12dp"

                app:icon="@drawable/usa1"
                app:iconGravity="textEnd"
                app:iconSize="28dp"
                app:iconPadding="20dp"
                android:paddingEnd="40dp"

                app:iconTint="@null"
                app:strokeColor="#3D3D3D"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAr"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#262626"
                android:text="العربية"
                android:textAllCaps="false"
                android:textColor="#BFBFBF"
                app:cornerRadius="12dp"

                app:icon="@drawable/ksa"
                app:iconGravity="textEnd"
                app:iconSize="28dp"
                app:iconPadding="25dp"
                android:paddingEnd="40dp"

                app:iconTint="@null"
                app:strokeColor="#3D3D3D"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>