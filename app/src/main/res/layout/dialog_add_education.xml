<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111111"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="32dp">

    <!-- HANDLE BAR -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="#444444"/>

    <!-- TITLE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📘  Study Session"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- SUBTITLE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Plan your education session"
        android:textColor="#2196F3"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="28dp"/>

    <!-- MODULE NAME -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilModuleName"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Module Name"
        app:hintTextColor="#888888"
        app:boxStrokeColor="#2196F3"
        app:boxBackgroundColor="#1A1A1A">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etModuleName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:inputType="text"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- STUDY PLAN -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilStudyPlan"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Study Plan (ex: 2h Chapter + 1h Practice)"
        app:hintTextColor="#888888"
        app:boxStrokeColor="#2196F3"
        app:boxBackgroundColor="#1A1A1A">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etStudyPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:inputType="textMultiLine"
            android:minLines="2"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- START TIME -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilStartTime"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Start Time"
        app:hintTextColor="#888888"
        app:boxStrokeColor="#2196F3"
        app:boxBackgroundColor="#1A1A1A"
        app:endIconMode="custom"
        app:endIconDrawable="@drawable/alarm_24px"
        app:endIconTint="#2196F3">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etStartTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- END TIME -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilEndTime"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:hint="End Time"
        app:hintTextColor="#888888"
        app:boxStrokeColor="#2196F3"
        app:boxBackgroundColor="#1A1A1A"
        app:endIconMode="custom"
        app:endIconDrawable="@drawable/alarm_24px"
        app:endIconTint="#2196F3">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEndTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- SAVE BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveSession"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="SAVE SESSION"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        android:backgroundTint="#2196F3"/>

</LinearLayout>