<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════════════════════════════════ MAIN CONTENT -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:padding="24dp">

        <!-- LET'S GO — anchored to bottom -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLetsGo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="12dp"
            android:text="Let's Go 🔥"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            app:backgroundTint="#FF6D00"
            app:cornerRadius="16dp"/>

        <!-- Content fills above button -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/btnLetsGo"
            android:orientation="vertical">

            <!-- ── TOP BAR — same structure as education ──────────────── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="28dp">

                <FrameLayout
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle_dark"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_back"
                        android:contentDescription="Back"
                        app:tint="#FFFFFF" />
                </FrameLayout>

                <!-- Gym icon centered -->
                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_centerInParent="true"
                    android:background="@drawable/bg_agenda_icon">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_fitness_center"
                        android:contentDescription="Gym"
                        app:tint="#FF6D00" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/menu_24px"
                    android:contentDescription="Menu"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#FFFFFF" />

            </RelativeLayout>

            <!-- ── GYM badge ────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GYM"
                android:textColor="#FF6D00"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:background="@drawable/bg_task_badge"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="14dp"/>

            <!-- ── Body Part Title ─────────────────────────────────── -->
            <TextView
                android:id="@+id/tvBodyPart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chest &amp; Triceps"
                android:textColor="#F9FAFB"
                android:textSize="26sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp"/>

            <!-- ── Info card ───────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_info_card"
                android:padding="16dp">

                <!-- Exercises count -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Exercises"
                        android:textColor="#6B7280"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvExCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="—"
                        android:textColor="#F9FAFB"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_time_badge"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"/>
                </RelativeLayout>

                <!-- Start time -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Start time"
                        android:textColor="#6B7280"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvStartTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="07:30"
                        android:textColor="#F9FAFB"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_time_badge"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"/>
                </RelativeLayout>

                <!-- Status -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Status"
                        android:textColor="#6B7280"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Pending"
                        android:textColor="#F59E0B"
                        android:textSize="12sp"
                        android:background="@drawable/bg_status_pending"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"/>
                </RelativeLayout>

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

    <!-- ═══════════════════════════════════════════ RIGHT DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#111111"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="55dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditPlan"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Edit Plan"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginBottom="14dp"
                app:backgroundTint="#1A0D00"
                app:icon="@drawable/ic_edit"
                app:iconTint="#FF6D00"
                app:iconPadding="10dp"
                app:iconGravity="textStart"
                app:cornerRadius="8dp"/>

            <!-- ★ NEW — Week Plan -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWeekPlan"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Week Plan"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginBottom="14dp"
                app:backgroundTint="#1A0D00"
                app:icon="@drawable/ic_calendar"
                app:iconTint="#FF6D00"
                app:iconPadding="10dp"
                app:iconGravity="textStart"
                app:cornerRadius="8dp"
                app:strokeColor="#FF6D00"
                app:strokeWidth="1dp"/>

        </LinearLayout>

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>