<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ═══════════════════════════════════ WARM-UP OVERLAY -->
    <FrameLayout
        android:id="@+id/warmupOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="visible"
        android:elevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NO\nEXCUSE"
                android:textColor="#FF6D00"
                android:textSize="48sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:gravity="center"
                android:lineSpacingMultiplier="0.9"
                android:layout_marginBottom="16dp"/>

            <View
                android:layout_width="48dp"
                android:layout_height="2dp"
                android:background="#FF6D00"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Warm-up"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="40dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWarmupLetsGo"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:text="Let's Go 🔥"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="14dp"
                app:backgroundTint="#FF6D00"
                app:cornerRadius="28dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWarmupSkip"
                android:layout_width="220dp"
                android:layout_height="48dp"
                android:text="Skip"
                android:textColor="#9CA3AF"
                android:textSize="15sp"
                app:backgroundTint="#1A1A1A"
                app:cornerRadius="24dp"
                app:strokeColor="#2A2A2A"
                app:strokeWidth="1dp"/>

        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════════════════ MAIN WORKOUT CONTENT -->
    <LinearLayout
        android:id="@+id/workoutContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- ── TOP BAR ─────────────────────────────────────────── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="20dp">

            <FrameLayout
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_dark"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_arrow_back"
                    android:contentDescription="Back"
                    app:tint="#FFFFFF"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvWorkoutBodyPart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Workout"
                android:textColor="#F9FAFB"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/menu_24px"
                android:contentDescription="Menu"
                android:clickable="true"
                android:focusable="true"
                app:tint="#FFFFFF"/>

        </RelativeLayout>

        <!-- ── SCROLLABLE BODY ────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Exercise cards injected here -->
                <LinearLayout
                    android:id="@+id/exercisesWorkoutContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- ── REST TIMER OVERLAY — modern circular, no skip button ──── -->
        <!--
            Visibility = gone par défaut.
            Java katbyan/tkhibi had overlay.
            CircularTimerView (custom view) katrasm l-cercle progressif.
        -->
        <FrameLayout
            android:id="@+id/restTimerOverlay"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone"
            android:alpha="0"
            android:gravity="center"
            android:background="#000000">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Label "REST" -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REST"
                    android:textColor="#4B5563"
                    android:textSize="12sp"
                    android:letterSpacing="0.3"
                    android:layout_marginBottom="20dp"/>

                <!-- CircularTimerView: cercle progressif + chiffres f lwst -->
                <!-- Size: 220dp x 220dp — programmé f Java -->
                <com.example.noexcuse.widget.CircularTimerView
                    android:id="@+id/circularTimer"
                    android:layout_width="220dp"
                    android:layout_height="220dp"/>

            </LinearLayout>

        </FrameLayout>

        <!-- ── ACTION BUTTON (Start / Next / Save) ─── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartWorkout"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:text="▶"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                app:backgroundTint="#22C55E"
                app:cornerRadius="40dp"
                app:strokeColor="#16A34A"
                app:strokeWidth="2dp"/>

        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>