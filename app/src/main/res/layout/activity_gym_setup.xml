<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- ══════════════════════════════════════════════════════════════════════
         STEP 1 — Sélection des jours
    ════════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/stepOneContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- HEADER STEP 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp">

            <!-- LIGNE HAUT : back arrow à gauche + logo centré -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- BACK ARROW — même style que task detail -->
                <ImageView
                    android:id="@+id/btnBackStepOne"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#AAAAAA"/>

                <!-- LOGO centré (weight pour occuper espace restant) -->
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="40dp"
                    android:src="@drawable/logo"
                    android:scaleType="centerInside"
                    android:layout_gravity="center_horizontal"/>

            </LinearLayout>

            <!-- TITRE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Set Up Your Week"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp"/>

            <!-- SOUS-TITRE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select your training days and muscle groups"
                android:textColor="#888888"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A1A"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>

        <!-- LISTE DES JOURS (scrollable) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/daysContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

        </ScrollView>

        <!-- BOUTON NEXT -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_margin="20dp"
            android:text="NEXT  →"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:backgroundTint="#FF6D00"
            app:cornerRadius="16dp"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════════
         STEP 2 — Exercices planifiés
    ════════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/stepTwoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- HEADER STEP 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="12dp">

            <!-- LIGNE HAUT : back arrow + titre + progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <!-- BACK ARROW — même style que task detail -->
                <ImageView
                    android:id="@+id/btnBackStepTwo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#AAAAAA"/>

                <!-- TITRE -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Plan Exercises"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginStart="8dp"/>

                <!-- PROGRESS ex: "2 / 4" -->
                <TextView
                    android:id="@+id/tvDayProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 / 3"
                    android:textColor="#FF6D00"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/badge_orange_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

            </LinearLayout>

            <!-- NOM DU JOUR COURANT -->
            <TextView
                android:id="@+id/tvCurrentDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monday — Chest"
                android:textColor="#FF6D00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.03"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="4dp"/>

            <!-- HINT -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add exercises for this day. Tap + to add more."
                android:textColor="#444444"
                android:textSize="12sp"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A1A"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>

        <!-- LISTE DES EXERCICES (scrollable) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/exercisesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

        </ScrollView>

        <!-- BOUTON AJOUTER EXERCICE -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddExercise"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp"
            android:text="+ Add Exercise"
            android:textColor="#FF6D00"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textSize="14sp"
            app:strokeColor="#FF6D00"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"/>

        <!-- BOUTONS NAVIGATION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp"
            android:gravity="center">

            <!-- NEXT DAY — couleur bleue/grise (machi orange) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextDay"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Next Day  →"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:backgroundTint="#1E3A5F"
                app:cornerRadius="14dp"
                android:visibility="gone"/>

            <!-- SAVE ALL — vert -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveAll"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="💾  Save Plan"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:backgroundTint="#1B4332"
                app:cornerRadius="14dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>