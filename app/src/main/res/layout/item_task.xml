<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardElevation="0dp"
    app:strokeColor="#2A2A2A"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp">

        <!-- Left accent bar -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="3dp"
            android:layout_height="0dp"
            android:background="#7C3AED"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- TASK / EDUCATION label — top-left above title -->
        <TextView
            android:id="@+id/tvTaskLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TASK"
            android:textColor="#7C3AED"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@+id/accentBar"
            android:layout_marginStart="14dp"/>

        <!-- Title — below label, vertically centered in remaining space -->
        <TextView
            android:id="@+id/tvItemTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Task Title"
            android:textColor="#F9FAFB"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@+id/tvTaskLabel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/accentBar"
            app:layout_constraintEnd_toStartOf="@+id/tvItemTime"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"/>

        <!-- Time — top-right -->
        <TextView
            android:id="@+id/tvItemTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:30"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:background="@drawable/bg_time_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ✓ Done — below time, hidden by default -->
        <TextView
            android:id="@+id/tvDoneCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Done"
            android:textColor="#81C784"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/tvItemTime"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="3dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>