<?xml version="1.0" encoding="utf-8"?>
<!--
  item_week_day.xml
  Card dyal kol nhar f week plan.
  CHANGE: rowStats — gha tvExCount (machi tvSetCount wla time)
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="16dp"
    app:strokeColor="#2A2A2A"
    app:strokeWidth="1dp"
    app:cardElevation="0dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HEADER ROW ────────────────────────────────── -->
        <RelativeLayout
            android:id="@+id/rowHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/accentBar"
                android:layout_width="4dp"
                android:layout_height="42dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="#FF6D00"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/accentBar"
                android:layout_marginStart="14dp"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDayName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONDAY"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvBodyPart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rest Day"
                    android:textColor="#F9FAFB"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvStartTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="#F9FAFB"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_time_badge"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="10dp"/>

                <ImageView
                    android:id="@+id/ivExpand"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/outline_arrow_drop_down_24"
                    android:contentDescription="Expand"
                    app:tint="#6B7280"/>
            </LinearLayout>

        </RelativeLayout>

        <!-- ── STATS ROW — gha exercise count, machi time ── -->
        <LinearLayout
            android:id="@+id/rowStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="34dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <!-- e.g. "6 exercises" -->
            <TextView
                android:id="@+id/tvExCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 exercises"
                android:textColor="#6B7280"
                android:textSize="12sp"/>

            <!-- tvSetCount kept for Java compat but hidden -->
            <TextView
                android:id="@+id/tvSetCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:visibility="gone"/>

        </LinearLayout>

        <!-- ── EXERCISES LIST (collapsible) ────────────── -->
        <LinearLayout
            android:id="@+id/layoutExercises"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="34dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:visibility="gone"/>

        <!-- ── EDIT ROW ──────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/rowEditActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="34dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditTime"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="Edit Time"
                android:textColor="#FF6D00"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:layout_marginEnd="8dp"
                app:backgroundTint="#1A0D00"
                app:cornerRadius="10dp"
                app:strokeColor="#FF6D00"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditExercises"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="Edit PlanExercises"
                android:textColor="#FF6D00"
                android:textSize="12sp"
                android:textAllCaps="false"
                app:backgroundTint="#1A0D00"
                app:cornerRadius="10dp"
                app:strokeColor="#FF6D00"
                app:strokeWidth="1dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>