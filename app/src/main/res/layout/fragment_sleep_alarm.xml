<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_sleep_alarm.xml — redesigned -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Header ──────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Excuse"
            android:textColor="#444444"
            android:textSize="10sp"
            android:letterSpacing="0.18"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sleep &amp; Alarm"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set your schedule. Sleep better. Wake stronger."
            android:textColor="#444444"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="32dp"/>

        <!-- ── Wake-up Time ───────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰  WAKE-UP TIME"
            android:textColor="#555555"
            android:textSize="9sp"
            android:letterSpacing="0.20"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardWakeTime"
            android:layout_width="match_parent"
            android:layout_height="116dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sleep_alarm_wake_card"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_alarm_card_scrim"/>

                <TextView
                    android:id="@+id/tvWakeTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="18dp"
                    android:text="07:00"
                    android:textColor="#FFFFFF"
                    android:textSize="52sp"
                    android:fontFamily="sans-serif-light"
                    android:shadowColor="#AA000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="8"
                    android:letterSpacing="-0.03"/>

            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Sleep Time ─────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙  SLEEP TIME"
            android:textColor="#555555"
            android:textSize="9sp"
            android:letterSpacing="0.20"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSleepTime"
            android:layout_width="match_parent"
            android:layout_height="116dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sleep_alarm_night_card"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_alarm_card_scrim"/>

                <TextView
                    android:id="@+id/tvSleepTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="18dp"
                    android:text="23:00"
                    android:textColor="#FFFFFF"
                    android:textSize="52sp"
                    android:fontFamily="sans-serif-light"
                    android:shadowColor="#AA000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="8"
                    android:letterSpacing="-0.03"/>

            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Smart Alarm Card ───────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔  SMART ALARM"
            android:textColor="#555555"
            android:textSize="9sp"
            android:letterSpacing="0.20"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardAlarmToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Title row + toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <!-- Title group -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alarm"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wake-up alert"
                            android:textColor="#444444"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <!-- Modern Switch toggle -->
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAlarm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        app:thumbTint="#FFFFFF"
                        app:trackTint="@color/alarm_switch_track"
                        app:trackDecorationTint="@null"/>

                </LinearLayout>

                <!-- Status indicator row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <!-- Status dot (green when ON, dark when OFF) -->
                    <View
                        android:id="@+id/viewStatusDot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/bg_status_dot"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvAlarmStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alarm is off"
                        android:textColor="#555555"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#1E1E1E"
                    android:layout_marginBottom="14dp"/>

                <!-- Sleep duration summary -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sleep duration"
                        android:textColor="#444444"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvSleepDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8h 00m"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── QR Dismiss Card — SEPARATE, clean ─────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnQrInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#141414"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- QR icon box -->
                <LinearLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_qr_icon_box"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_qr_code"
                        app:tint="#555555"
                        android:contentDescription="QR code icon"/>

                </LinearLayout>

                <!-- Text group -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QR scan to dismiss"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="2dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan your code to fully stop the alarm"
                        android:textColor="#444444"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>

                <!-- Chevron -->
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#333333"
                    android:contentDescription="More info"
                    android:layout_marginStart="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Save Button ────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAlarm"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Alarm"
            android:textColor="#0D0D0D"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="27dp"
            app:elevation="0dp"/>

    </LinearLayout>
</ScrollView>
