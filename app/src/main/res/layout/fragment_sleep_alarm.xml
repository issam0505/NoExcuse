<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_sleep_alarm.xml -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sleep &amp; Alarm"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set your schedule. Sleep better. Wake stronger."
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginBottom="32dp"/>

        <!-- ── Wake-up Time ───────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰  WAKE-UP TIME"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvWakeTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="07:00"
                    android:textColor="#FFFFFF"
                    android:textSize="48sp"
                    android:fontFamily="sans-serif-thin"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_edit"
                    app:tint="#444444"
                    android:contentDescription="Edit wake time"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Sleep Time ─────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙  SLEEP TIME"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSleepTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="23:00"
                    android:textColor="#FFFFFF"
                    android:textSize="48sp"
                    android:fontFamily="sans-serif-thin"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_edit"
                    app:tint="#444444"
                    android:contentDescription="Edit sleep time"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Alarm Toggle ───────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable Smart Alarm"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QR scan required to fully dismiss"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/swAlarmEnabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="#FFFFFF"
                    app:trackTint="#333333"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── How it works info ──────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQrInfo"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❓ How does the QR alarm work?"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginBottom="28dp"/>

        <!-- ── Save Button ────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAlarm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Alarm"
            android:textColor="#0D0D0D"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="28dp"/>

    </LinearLayout>
</ScrollView>