<?xml version="1.0" encoding="utf-8"?>
<!--
  card_flip_in.xml
  Animation unique: 3D flip on Y axis + fade in
  Machi slide, machi fall — hadi flip kima carte ktqelba
  Duration: 500ms — fast w snappy
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/decelerate_interpolator">

    <!-- 3D rotate on Y axis: from 90° → 0° (flip in from right) -->
    <rotate
        android:fromDegrees="90"
        android:toDegrees="0"
        android:pivotX="0%"
        android:pivotY="50%"
        android:duration="450" />

    <!-- Fade in slightly delayed so flip starts before full opacity -->
    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:startOffset="80"
        android:duration="370" />

</set>